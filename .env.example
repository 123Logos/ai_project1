# 复制为 .env / .env.development / .env.production 后按需填写（勿把含真实地址的文件提交到 Git）
# 后端或同源代理根地址，见 src/api/config.ts
VITE_API_TARGET=https://your-api-host.example

# AI 比价 /tl、/auth 代理目标（可与 VITE_API_TARGET 相同）
VITE_TL_TARGET=https://your-api-host.example

# 电子地图高德地理编码（可选）
# VITE_AMAP_REST_KEY=
# VITE_AMAP_AUTO_PERSIST=1
# VITE_API_PROXY_INSECURE=1
